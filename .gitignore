# Root .gitignore
*

# Allow essential project structure
!.gitignore
!README.md
!.github/
!.github/**

# Allow ONLY backend directory content
!backend/
!backend/**

# Specific ignores inside backend
backend/firebase-credentials.json
backend/service_account*.json
backend/*.json
backend/db.sqlite3
backend/.env
backend/.env.*

# Global ignores
.env
.env.*
**/*.pyc
__pycache__/
*.log
node_modules/

# STRICTLY IGNORE mobile directory (User requested "apenas a pasta backend")
mobile/
